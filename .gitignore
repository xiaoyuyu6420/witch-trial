# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log

# env files (can opt-in for committing if needed)
.env
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# databases
*.db
*.db-journal

# IDE / editor artifacts
.idea/
.vscode/
*.swp
*.swo
*~

# development artifacts
.arts/
.codeartsdoer/
.playwright-mcp/
.claude/

# playwright artifacts
test-results/
playwright-report/

# screenshots & temp files in root
*.png
*.html
*.log

# allow committed static assets in public/
!public/
!public/**