# Witch Trial Environment Variables

# Admin password - IMPORTANT: Set a strong password in production!
ADMIN_PASSWORD=your_secure_password_here

# Database URL
# For development (SQLite)
DATABASE_URL=file:./dev.db

# For production (SQLite in Docker)
# DATABASE_URL=file:./data/witch-trial.db

# For production PostgreSQL (optional)
# DATABASE_URL="postgresql://username:password@host:port/database"

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Proxy trust for rate limiting (optional)
# "all"  = (default) Trust x-forwarded-for header. Use behind a reverse proxy (nginx, Caddy, etc.)
# "none" = Ignore x-forwarded-for entirely. Use when exposed directly without a reverse proxy.
# TRUSTED_PROXY=all

# Additional environment variables if needed
# NODE_ENV=production
