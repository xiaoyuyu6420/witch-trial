generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum QuestionType {
  normal
  gate
  trigger
}

model Question {
  id           Int          @id @default(autoincrement())
  dim          String
  text         String
  order        Int
  type         QuestionType @default(normal)
  meta         String       @default("")
  translations String       @default("{}")
  options      Option[]
  answers      Answer[]
}

model Option {
  id         Int      @id @default(autoincrement())
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String
  score      Int      @default(0)
  value      String?
  trigger    String?
}

model PersonalityType {
  id           Int     @id @default(autoincrement())
  code         String  @unique
  name         String
  subtitle     String?
  group        String
  vector       String
  slogan       String
  desc         String
  keywords     String?
  special      Boolean @default(false)
  translations String  @default("{}")
}

model TestRecord {
  id           Int      @id @default(autoincrement())
  sessionId    String
  resultCode   String
  similarity   Float
  userVector   String
  top3         String
  borderType   Boolean  @default(false)
  gateValue    String?
  triggerFired String?
  createdAt    DateTime @default(now())
  answers      Answer[]

  userAgent    String?
  ipAddress    String?
  screenRes    String?
  language     String?
  timezone     String?
  startedAt    DateTime?
  completedAt  DateTime?
  duration     Int?

  @@index([resultCode])
  @@index([createdAt])
  @@index([sessionId])
}

model Answer {
  id         Int        @id @default(autoincrement())
  recordId   Int
  record     TestRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  questionId Int
  question   Question   @relation(fields: [questionId], references: [id])
  optionId   Int
}
